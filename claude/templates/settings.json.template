{
  "model": "opus",
  "enabledPlugins": {},
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Read(**)",
      "Read(~/**)",
      "Read(/**)",
      "Read(~/.claude/**)",
      "Read(/Users/{{MACHINE_USER}}/.claude/**)",
      "Glob(**)",
      "Glob(~/**)",
