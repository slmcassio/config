# Example profile — copy to config-private/claude/profiles/<machinename>.env
# The filename (without .env) is the profile name used with --profile.
# install.sh auto-detects the right profile by matching MACHINE_USER to whoami.

# Your macOS/Linux username (output of: whoami)
MACHINE_USER=your.username

# Directory under ~ where you clone repos (no leading slash, no ~)
DEV_DIR=Developer

# Path from ~ to the config repo root — grants Claude edit access to its own config
# Must match where you cloned config/ (e.g. Developer/config or projects/config)
CONFIG_SUBPATH=Developer/config

# Path from ~ where Claude agent worktrees are created
# install.sh uses this to grant Claude rm access for worktree cleanup
WORKTREES_DIR_REL=Developer/claude-working-here
