{
  "breadcrumbs.enabled": false,
  "editor.tabFocusMode": false,
  "editor.fontFamily": "'JetBrains Mono', Menlo, Monaco, 'Courier New', monospace",
  "editor.fontSize": 13,
  "editor.fontLigatures": true,
  "editor.formatOnSave": false,
  "editor.gotoLocation.alternativeDeclarationCommand": "",
  "editor.gotoLocation.alternativeDefinitionCommand": "",
  "editor.gotoLocation.alternativeTypeDefinitionCommand": "",
  "editor.lineNumbers": "relative",
  "editor.cursorSurroundingLines": 8,
  "editor.minimap.enabled": false,
  "git.path": "/usr/bin/git",
  "vim.enableNeovim": true,
  "vim.highlightedyank.duration": 700,
  "vim.highlightedyank.enable": true,
  "vim.highlightedyank.color": "rgba(245, 194, 231, 0.3)",
  "vim.highlightedyank.textColor": "#45475a",
  "vim.neovimPath": "/opt/homebrew/bin/nvim",
  "vim.normalModeKeyBindingsNonRecursive": [
    {
      "before": [
        "<C-Space>"
      ],
      "commands": [
        "vspacecode.space"
      ]
    },
    {
      "before": [
        "<Space>"
      ],
      "commands": [
        "vspacecode.space"
      ]
    },
    {
      "before": [
        "g",
        "h"
      ],
      "commands": [
        "editor.action.showHover"
      ]
    },
    {
      "before": [
        "g",
        "i"
      ],
      "commands": [
        "editor.action.goToImplementation"
      ]
    },
    {
      "before": [
        "g",
        "r"
      ],
      "commands": [
        "editor.action.goToReferences"
      ]
    },
    {
      "before": [
        "g",
        "R"
      ],
      "commands": [
        "editor.action.rename"
      ]
    },
    {
      "before": [
        "g",
        "f"
      ],
      "commands": [
        "editor.action.formatDocument"
      ]
    },
    {
      "before": [
        "g",
        "F"
      ],
      "commands": [
        "editor.action.formatSelection"
      ]
    },
    {
      "before": [
        ","
      ],
      "commands": [
        "vspacecode.space",
        {
          "command": "whichkey.triggerKey",
          "args": ","
        }
      ]
    },
    {
      "before": [
        ";"
      ],
      "commands": [
        "vspacecode.space",
        {
          "command": "whichkey.triggerKey",
          "args": ";"
        }
      ]
    },
    {
      "before": [
        "m",
        "j"
      ],
      "commands": [
        "editor.action.insertCursorBelow"
      ]
    },
    {
      "before": [
        "m",
        "k"
      ],
      "commands": [
        "editor.action.insertCursorAbove"
      ]
    },
    {
      "before": [
        "m",
        "J"
      ],
      "commands": [
        "editor.action.addSelectionToNextFindMatch"
      ]
    },
    {
      "before": [
        "m",
        "K"
      ],
      "commands": [
        "editor.action.addSelectionToPreviousFindMatch"
      ]
    },
    {
      "before": [
        "z",
        "s"
      ],
      "commands": [
        "paredit.slurpSexpForward"
      ]
    },
    {
      "before": [
        "z",
        "S"
      ],
      "commands": [
        "paredit.slurpSexpBackward"
      ]
    },
    {
      "before": [
        "z",
        "b"
      ],
