                {
                  "key": "s",
                  "name": "Eval selection",
                  "type": "command",
                  "command": "calva.evaluateSelection"
                },
                {
                  "key": "l",
                  "name": "Load/eval file",
                  "type": "command",
                  "command": "calva.loadFile"
                },
                {
                  "key": "r",
                  "name": "Refresh changed namespaces",
                  "type": "command",
                  "command": "calva.refresh"
                },
                {
                  "key": "a",
                  "name": "Refresh all namespaces",
                  "type": "command",
