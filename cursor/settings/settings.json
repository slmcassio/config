      ]
    },
    {
      "before": [
        "z",
        "B"
      ],
      "commands": [
        "paredit.barfSexpBackward"
      ]
    },
    {
      "before": [
        "z",
        "r"
      ],
      "commands": [
        "paredit.raiseSexp"
      ]
    },
    {
      "before": [
        "z",
        "x"
      ],
      "commands": [
        "paredit.spliceSexp"
      ]
    },
    {
      "before": [
        "m",
        "c"
      ],
      "commands": [
        "editor.action.commentLine"
      ]
    },
    {
      "before": [
        "m",
        "C"
      ],
      "commands": [
        "editor.action.blockComment"
      ]
    }
  ],
