  "vim.useSystemClipboard": true,
  "vspacecode.bindings": [
    {
      "key": " ",
      "name": "Command palette",
      "type": "command",
      "command": "workbench.action.showCommands"
    },
    {
      "key": "/",
      "name": "Search Editor",
      "type": "command",
      "command": "search.action.openEditor"
    },
    {
      "key": "?",
      "name": "Search keybindings",
      "type": "command",
      "command": "whichkey.searchBindings"
    },
    {
      "key": "Q",
      "name": "Quit Cursor",
      "type": "command",
      "command": "workbench.action.quit"
    },
    {
      "key": "q",
      "name": "Close window",
      "type": "command",
      "command": "workbench.action.closeWindow"
    },
    {
      "key": "w",
      "name": "Save file",
      "type": "command",
      "command": "workbench.action.files.save"
    },
    {
      "key": "W",
      "name": "Save file as",
      "type": "command",
      "command": "workbench.action.files.saveAs"
    },
    {
      "key": ";",
      "name": "+Cursor [;]",
      "type": "bindings",
      "bindings": [
        {
          "key": "c",
          "name": "Chat",
          "type": "command",
          "command": "composer.startComposerPrompt"
        },
        {
          "key": "n",
          "name": "New chat",
          "type": "command",
          "command": "composer.createNewWithPrevContext"
        },
        {
          "key": "N",
          "name": "New chat tab",
          "type": "command",
          "command": "composer.createNewComposerTab"
        },
        {
          "key": "e",
          "name": "+Edits",
          "type": "bindings",
          "bindings": [
            {
              "key": "a",
              "name": "Accept all diffs [cmd+enter]",
              "type": "command",
              "command": "editor.action.inlineDiffs.acceptAll"
            },
            {
              "key": "y",
              "name": "Accept partial edit [cmd+y]",
              "type": "command",
              "command": "editor.action.inlineDiffs.acceptPartialEdit"
            },
            {
              "key": "A",
              "name": "Accept all files (chat) [cmd+enter]",
              "type": "command",
              "command": "chatEditing.acceptAllFiles"
            },
            {
              "key": "p",
              "name": "Reject partial edit [cmd+n]",
              "type": "command",
              "command": "editor.action.inlineDiffs.rejectPartialEdit"
            },
            {
              "key": "r",
              "name": "Reject all diffs [cmd+backspace]",
              "type": "command",
              "command": "editor.action.inlineDiffs.rejectAll"
            },
            {
              "key": "R",
              "name": "Reject all across editors [cmd+ctrl]",
              "type": "command",
              "command": "editor.action.inlineDiffs.rejectAllAcrossAllEditors"
            },
            {
              "key": "d",
              "name": "Discard all files (chat) [cmd+backspace]",
              "type": "command",
              "command": "chatEditing.discardAllFiles"
            },
            {
              "key": "j",
              "name": "Next inline diff [alt+j]",
              "type": "command",
              "command": "editor.action.inlineDiffs.nextChange"
            },
            {
              "key": "k",
              "name": "Previous inline diff [alt+k]",
              "type": "command",
              "command": "editor.action.inlineDiffs.previousChange"
            },
            {
              "key": "m",
              "name": "Composer mode menu [cmd+.]",
              "type": "command",
              "command": "composer.openModeMenu"
            },
            {
              "key": "M",
              "name": "Model toggle [cmd+/]",
              "type": "command",
              "command": "composer.openModelToggle"
            }
          ]
        },
        {
          "key": "t",
          "name": "Toggle menu",
          "type": "command",
          "command": "workbench.action.toggleAuxiliaryBar"
        },
        {
          "key": "S",
          "name": "Cursor settings",
          "type": "command",
          "command": "aiSettings.action.open"
        }
      ]
    },
    {
      "key": ",",
      "name": "+Local [,]",
      "type": "conditional",
      "bindings": [
